# Community Configuration (seeds the default client record on startup)
CLIENT_NAME=default
COMMUNITY_NAME=
COMMUNITY_DESCRIPTION=
INVITE_LINK=
AGENT_NAME=
AGENT_TONE=warm and conversational
WEBHOOK_SECRET=

# Links (optional)
CALENDLY_LINK=
FOUNDER_STORIES_LINK=
OPERATOR_SESSION_LINK=

# Timing
FOLLOW_UP_DELAY_MINS=30
ABANDON_AFTER_HOURS=24
NUDGE_DELAY_MINS=30
TIMEOUT_HOURS=24
ENGAGEMENT_THRESHOLD=0.3
ENGAGEMENT_DAYS=14

# PostgreSQL
# Use this for hosted Postgres providers like Neon. Include sslmode=require.
DATABASE_URL=

# Or use these for local Docker Postgres.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=onboardme
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# AI Provider (Groq active, Claude ready)
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# WhatsApp Bridge
WHATSAPP_BRIDGE_URL=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
